# Tractus-X Local Dataspace Environment Variables

# Participants
BPN_PROVIDER=BPNL00000003AYRE
BPN_CONSUMER=BPNL00000003AZQP
BPN_ISSUER=BPNL00000003CRHK

# DID resolution
DID_HOST=identity-hub

# Database
POSTGRES_USER=user
POSTGRES_PASSWORD=password

# Vault
VAULT_DEV_ROOT_TOKEN_ID=root

# Management API key
EDC_API_KEY=password

# STS client secrets
PROVIDER_STS_SECRET=provider-sts-secret
CONSUMER_STS_SECRET=consumer-sts-secret

# BDRS
BDRS_DB_USER=bdrs
BDRS_DB_PASSWORD=bdrspassword
BDRS_API_KEY=password

# Identity Hub
IDENTITYHUB_TAG=0.1.0-20260209-SNAPSHOT

# Java memory limit for all services
JAVA_TOOL_OPTIONS=-Xmx256m
